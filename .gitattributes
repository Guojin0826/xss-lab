# Auto detect text files and perform LF normalization
* text=auto

# PHP files
*.php text eol=lf

# HTML files
*.html text eol=lf

# JavaScript files
*.js text eol=lf

# CSS files
*.css text eol=lf

# Markdown files
*.md text eol=lf

# JSON files
*.json text eol=lf

# YAML files
*.yml text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary